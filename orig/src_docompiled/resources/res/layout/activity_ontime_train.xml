<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white_menu_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_top_bar_ontime"
        android:background="@color/text_menu_checked"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <com.coollang.tennis.widget.RippleView
            android:id="@+id/leftBtn"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            app:rv_centered="true"
            app:rv_rippleDuration="100">
            <Button
                android:textSize="15sp"
                android:textColor="@color/white_menu_bg"
                android:id="@+id/bt_left"
                android:background="@drawable/ic_button_back"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginLeft="20dp"
                android:layout_centerInParent="true"/>
        </com.coollang.tennis.widget.RippleView>
        <RadioGroup
            android:orientation="horizontal"
            android:id="@+id/rg_sport_detail"
            android:background="@drawable/shape_rg_white_bg"
            android:layout_width="200dp"
            android:layout_height="30dp"
            android:layout_centerInParent="true">
            <RadioButton
                android:textSize="@dimen/on_time_train_rb_tx_size"
                android:textColor="@color/selector_green_white_color"
                android:gravity="center"
                android:id="@+id/rb_hand_train"
                android:background="@drawable/selector_sport_detail_top_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:checked="true"
                android:button="@null"
                android:text="@string/hand_train"
                android:layout_weight="1"/>
            <RadioButton
                android:textSize="@dimen/on_time_train_rb_tx_size"
                android:textColor="@color/selector_green_white_color"
                android:gravity="center"
                android:id="@+id/rb_send_train"
                android:background="@drawable/selector_sport_detail_top_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:button="@null"
                android:text="@string/send_train"
                android:layout_weight="1"/>
        </RadioGroup>
        <com.coollang.tennis.widget.RippleView
            android:id="@+id/rightImage"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            app:rv_alpha="0"
            app:rv_zoom="true"
            app:rv_zoomScale="1.3">
            <ImageView
                android:id="@+id/img_connect_on_time"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/device_unconnect_anim"/>
        </com.coollang.tennis.widget.RippleView>
    </RelativeLayout>
    <com.coollang.tennis.widget.NoScrollViewPager
        android:id="@+id/vp_train_sport"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/rl_top_bar_ontime"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_re_connecting"
        android:background="@drawable/shape_on_time_re_connect"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="8dp"
        android:text="@string/re_connectting_device"
        android:layout_below="@+id/rl_top_bar_ontime"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
