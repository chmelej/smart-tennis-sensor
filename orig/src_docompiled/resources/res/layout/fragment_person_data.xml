<?xml version="1.0" encoding="utf-8"?>
<com.coollang.tennis.widget.ObservableScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/scroll"
    android:background="@color/white"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="200dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:text="@string/all_sport_data"
            style="@style/person_per_title_style"/>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/yellow_re_start_ble"
                    android:id="@+id/tv_use_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="#787878"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/person_active_time"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/yellow_re_start_ble"
                    android:id="@+id/tv_hit_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="#787878"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/person_hit_count"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:background="@drawable/shape_person_year_bg"
            android:layout_width="180dp"
            android:layout_height="30dp"
            android:layout_marginTop="24dp">
            <ImageView
                android:id="@+id/img_person_year_left"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/arrow_person_left_no"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#151515"
                android:gravity="center"
                android:id="@+id/tv_year_show_person"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/img_person_year_right"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/arrow_person_right_no"/>
        </LinearLayout>
        <android.support.v4.view.ViewPager
            android:id="@+id/vp_chart_year_data"
            android:layout_width="match_parent"
            android:layout_height="230dp"/>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <TextView
            android:text="@string/person_data_best"
            style="@style/person_per_title_style"/>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_person_best_data"
            android:paddingTop="4dp"
            android:paddingBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <TextView
            android:text="@string/average"
            style="@style/person_per_title_style"/>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="90dp">
            <include
                android:id="@+id/fore_speed_data"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/layout_person_avg"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="1px"
                android:layout_height="match_parent"/>
            <include
                android:id="@+id/back_speed_data"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/layout_person_avg"/>
        </LinearLayout>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="90dp">
            <include
                android:id="@+id/send_speed_data"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/layout_person_avg"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="1px"
                android:layout_height="match_parent"/>
            <include
                android:id="@+id/sport_score_data"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/layout_person_avg"/>
        </LinearLayout>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="90dp">
            <include
                android:id="@+id/sport_time_data"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/layout_person_avg"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="1px"
                android:layout_height="match_parent"/>
            <include
                android:id="@+id/sport_count_data"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                layout="@layout/layout_person_avg"/>
        </LinearLayout>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
    </LinearLayout>
</com.coollang.tennis.widget.ObservableScrollView>
