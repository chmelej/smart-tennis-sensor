<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/sport_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/navigation_relativelayout"/>
    <android.support.v7.widget.CardView
        android:layout_gravity="center_horizontal"
        android:layout_width="338dp"
        android:layout_height="87dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">
        <LinearLayout
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="23dp">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_menu"
                    android:gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/train_time"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_menu"
                    android:gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/train_hand_deep_type"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_menu"
                    android:gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/train_finish_status"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:baselineAligned="false">
                <LinearLayout
                    android:gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:baselineAligned="true"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="26dp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow_re_start_ble"
                        android:id="@+id/tv_train_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/yellow_re_start_ble"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/sport_now_unit"/>
                </LinearLayout>
                <TextView
                    android:textSize="22dp"
                    android:textStyle="bold"
                    android:textColor="@color/yellow_re_start_ble"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_train_level"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="22dp"
                    android:textStyle="bold"
                    android:textColor="@color/yellow_re_start_ble"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_train_finish_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </android.support.v7.widget.CardView>
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp">
        <RadioGroup
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/rg_target"
            android:background="@drawable/shape_rg_green_bg"
            android:layout_width="200dp"
            android:layout_height="30dp"
            android:layout_marginTop="17dp">
            <RadioButton
                android:textColor="@color/selector_white_green_color"
                android:gravity="center"
                android:id="@+id/rb_fore_hand_target"
                android:background="@drawable/selector_set_target_top_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:checked="true"
                android:button="@null"
                android:text="@string/Real_new_text111"
                android:layout_weight="1"/>
            <RadioButton
                android:textColor="@color/selector_white_green_color"
                android:gravity="center"
                android:id="@+id/rb_back_hand_target"
                android:background="@drawable/selector_set_target_top_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:button="@null"
                android:text="@string/Real_new_text122"
                android:layout_weight="1"/>
        </RadioGroup>
    </LinearLayout>
    <android.support.v4.view.ViewPager
        android:id="@+id/vp_train_sport"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="20dp"/>
    <View
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="20dp"/>
</LinearLayout>
