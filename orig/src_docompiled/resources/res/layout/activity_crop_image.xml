<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.coollang.tennis.choosephoto.CropImageView
        android:id="@+id/activity_crop_image_crop_image_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <RelativeLayout
        android:id="@+id/activity_crop_image_rl"
        android:layout_width="match_parent"
        android:layout_height="200dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/rippelColor"
            android:id="@+id/activity_crop_image_tv_last_step"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/last_step"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/rippelColor"
            android:id="@+id/activity_crop_image_tv_next_step"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next_step"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <View
        android:layout_gravity="bottom"
        android:id="@+id/activity_crop_image_view"
        android:layout_width="match_parent"
        android:layout_height="200dp"/>
</FrameLayout>
