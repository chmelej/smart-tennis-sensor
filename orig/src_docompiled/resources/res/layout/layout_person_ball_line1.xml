<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:background="#f4f4f4"
    android:layout_width="match_parent"
    android:layout_height="80dp">
    <TextView
        android:textSize="16sp"
        android:textColor="#151515"
        android:gravity="center"
        android:id="@+id/tv_line_orientation"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/equip_main_left_margin"
        android:text="@string/ver_line"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="16sp"
        android:textColor="#aaaaaa"
        android:id="@+id/not_set_line"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/equip_main_rigth_part_margin"
        android:text="@string/not_setting"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_has_equip_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/equip_main_rigth_part_margin"
        android:layout_centerVertical="true">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="18sp"
                android:textColor="@color/yellow_re_start_ble"
                android:id="@+id/tv_line_name"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Technifibre"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#151515"
                android:id="@+id/tv_line_width"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="18dp"
                android:text="1.32mm"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#151515"
                android:id="@+id/tv_line_pound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="33lbs"/>
        </LinearLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="#151515"
            android:id="@+id/tv_line_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Cyber Black"/>
    </LinearLayout>
</RelativeLayout>
