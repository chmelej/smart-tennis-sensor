<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/sport_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/navigation_relativelayout"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="20dp"/>
    <EditText
        android:textSize="16sp"
        android:textColor="#787878"
        android:gravity="center_vertical"
        android:id="@+id/edt_nick_name_input"
        android:background="@color/white"
        android:paddingLeft="16dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:singleLine="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_input_sign"
        android:background="@color/white"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp">
        <EditText
            android:textSize="16sp"
            android:textColor="#787878"
            android:id="@+id/edt_sign_input"
            android:background="@android:color/transparent"
            android:paddingLeft="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="#aaaaaa"
            android:layout_gravity="bottom"
            android:id="@+id/tv_left_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="4dp"
            android:text="15"/>
    </LinearLayout>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
