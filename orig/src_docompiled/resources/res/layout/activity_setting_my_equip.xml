<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:baseLine="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/sport_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/navigation_relativelayout"/>
    <TextView
        android:textColor="#aaaaaa"
        android:text="@string/racket"
        style="@style/person_per_title_style"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <RelativeLayout
        android:id="@+id/rl_racket_img"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="64dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/text_apple_color"
            android:id="@+id/tv_racket_img_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:text="@string/equip_img"
            android:layout_centerVertical="true"/>
        <com.coollang.tennis.widget.CircleImageView
            android:id="@+id/img_racket_right"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginRight="16dp"
            android:src="@drawable/img_no_person_equip"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"/>
    <RelativeLayout
        android:id="@+id/rl_racket_factory"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="64dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/text_apple_color"
            android:id="@+id/tv_factory_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:text="@string/racket_factory_type"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/img_arrow_right"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginRight="16dp"
            android:src="@drawable/ic_person_setting_arrow"
            android:scaleType="center"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_toLeftOf="@+id/img_arrow_right"
            android:layout_toRightOf="@+id/tv_factory_title"
            android:layout_centerVertical="true">
            <TextView
                android:textSize="14sp"
                android:textColor="#787878"
                android:layout_gravity="right"
                android:id="@+id/tv_factory_racket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#787878"
                android:layout_gravity="right"
                android:id="@+id/tv_type_racket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"/>
        </LinearLayout>
    </RelativeLayout>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"/>
    <com.coollang.tennis.widget.BaseLineView
        android:id="@+id/blv_buy_day"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        baseLine:leftText="@string/buy_date"
        baseLine:leftTextColor="@color/text_apple_color"
        baseLine:leftTextSize="16sp"
        baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
        baseLine:rightTextColor="#787878"
        baseLine:rightTextSize="14sp"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"/>
    <com.coollang.tennis.widget.BaseLineView
        android:id="@+id/blv_ver_line"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        baseLine:leftText="@string/ver_line"
        baseLine:leftTextColor="@color/text_apple_color"
        baseLine:leftTextSize="16sp"
        baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
        baseLine:rightTextColor="#787878"
        baseLine:rightTextSize="14sp"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"/>
    <com.coollang.tennis.widget.BaseLineView
        android:id="@+id/blv_hor_line"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        baseLine:leftText="@string/hor_line"
        baseLine:leftTextColor="@color/text_apple_color"
        baseLine:leftTextSize="16sp"
        baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
        baseLine:rightTextColor="#787878"
        baseLine:rightTextSize="14sp"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <TextView
        android:textColor="#aaaaaa"
        android:text="@string/shoes"
        style="@style/person_per_title_style"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <RelativeLayout
        android:id="@+id/rl_shoes_img"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="64dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/text_apple_color"
            android:id="@+id/tv_shoes_img_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:text="@string/equip_img"
            android:layout_centerVertical="true"/>
        <com.coollang.tennis.widget.CircleImageView
            android:id="@+id/img_shoes_right"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginRight="16dp"
            android:src="@drawable/img_no_person_equip"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"/>
    <com.coollang.tennis.widget.BaseLineView
        android:id="@+id/blv_shoes_name"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        baseLine:leftText="@string/shoes_name"
        baseLine:leftTextColor="@color/text_apple_color"
        baseLine:leftTextSize="16sp"
        baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
        baseLine:rightTextColor="#787878"
        baseLine:rightTextSize="14sp"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="20dp"/>
    <com.coollang.tennis.widget.BaseLineView
        android:id="@+id/blv_shoes_buy_day"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        baseLine:leftText="@string/buy_date"
        baseLine:leftTextColor="@color/text_apple_color"
        baseLine:leftTextSize="16sp"
        baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
        baseLine:rightTextColor="#787878"
        baseLine:rightTextSize="14sp"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
