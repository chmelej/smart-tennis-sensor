<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app1="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:scrollbars="none"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:id="@+id/fragment_sport_resport_fl"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="20dp">
            <RelativeLayout
                android:layout_gravity="center"
                android:background="@drawable/bg_sport_report_circle"
                android:layout_width="160dp"
                android:layout_height="160dp">
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/line"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="@string/moto_score"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"/>
            </RelativeLayout>
            <com.coollang.tennis.widget.SportCircleProgressView
                android:layout_gravity="center"
                android:id="@+id/sport_report_circle"
                android:layout_width="200dp"
                android:layout_height="200dp"
                app1:isMultiColor="true"
                app1:ringWidth="8dp"/>
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.coollang.tennis.widget.CountView
                    android:textSize="60sp"
                    android:textColor="@color/yellow_re_start_ble"
                    android:id="@+id/countview_sport_report"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/yellow_re_start_ble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/score_unit"/>
            </LinearLayout>
        </FrameLayout>
        <View style="@style/sport_report_line"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="76dp">
            <TextView
                android:id="@+id/tv_sport_time_title"
                style="@style/sport_report_tv_title"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:gravity="center"
                android:id="@+id/tv_sport_time_count"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_sport_time_title"/>
            <TextView
                android:id="@+id/tv_sport_time_desc"
                style="@style/sport_report_tv_explain"/>
        </RelativeLayout>
        <View style="@style/sport_report_line"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="76dp">
            <TextView
                android:id="@+id/tv_sport_cal_title"
                style="@style/sport_report_tv_title"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:gravity="center"
                android:id="@+id/tv_sport_cal_count"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_sport_cal_title"/>
            <TextView
                android:id="@+id/tv_sport_cal_desc"
                style="@style/sport_report_tv_explain"/>
        </RelativeLayout>
        <View style="@style/sport_report_line"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="76dp">
            <TextView
                android:id="@+id/tv_sport_per_min_title"
                style="@style/sport_report_tv_title"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:gravity="center"
                android:id="@+id/tv_sport_per_min_count"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_sport_per_min_title"/>
            <TextView
                android:id="@+id/tv_sport_per_min_desc"
                style="@style/sport_report_tv_explain"/>
        </RelativeLayout>
        <View style="@style/sport_report_line"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="76dp">
            <TextView
                android:id="@+id/tv_sport_max_speed_title"
                style="@style/sport_report_tv_title"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:gravity="center"
                android:id="@+id/tv_sport_max_speed_count"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_sport_max_speed_title"/>
            <TextView
                android:id="@+id/tv_sport_max_speed_desc"
                style="@style/sport_report_tv_explain"/>
        </RelativeLayout>
        <View style="@style/sport_report_line"/>
    </LinearLayout>
</ScrollView>
