<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:baseLineView="http://schemas.android.com/apk/res-auto"
    android:background="@color/sport_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:background="@drawable/ic_person_setting_bcg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:id="@+id/rl_head"
                android:layout_width="match_parent"
                android:layout_height="48dp">
                <ImageView
                    android:id="@+id/iv_return"
                    android:padding="10dp"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_return"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/titleSize"
                    android:textColor="@color/white_menu_bg"
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/personal_text1"
                    android:layout_centerInParent="true"/>
                <ImageButton
                    android:id="@+id/activity_person_setting_ib_save"
                    android:background="@color/tranlete"
                    android:padding="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_person_setting_save"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/rl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_below="@+id/rl_head">
                <FrameLayout
                    android:id="@+id/fl_head"
                    android:background="@drawable/shap_ring_green"
                    android:layout_width="73dp"
                    android:layout_height="73dp"
                    android:layout_marginLeft="10dp">
                    <com.coollang.tennis.widget.CircleImageView
                        android:layout_gravity="center"
                        android:id="@+id/activity_personal_setting_iv_head"
                        android:layout_width="60dp"
                        android:layout_height="60dp"/>
                </FrameLayout>
                <EditText
                    android:textSize="18sp"
                    android:textColor="@color/sport_text_number"
                    android:id="@+id/activity_personal_setting_et_name"
                    android:background="@null"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="3dp"
                    android:hint="@string/pls_input_nicky"
                    android:maxLength="10"
                    android:drawableLeft="@drawable/ic_person_write"
                    android:layout_toRightOf="@+id/fl_head"/>
                <EditText
                    android:textSize="14sp"
                    android:textColor="@color/white_menu_bg"
                    android:id="@+id/activity_personal_setting_et_signature"
                    android:background="@null"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="@string/user_sign_default"
                    android:hint="@string/pls_input_sign"
                    android:drawableLeft="@drawable/ic_person_write"
                    android:layout_toRightOf="@+id/fl_head"
                    android:layout_below="@+id/activity_personal_setting_et_name"/>
            </RelativeLayout>
        </RelativeLayout>
        <com.coollang.tennis.widget.MyScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/shap_setting_bcg_round"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp">
                    <com.coollang.tennis.widget.BaseLineView
                        android:id="@+id/blv_setting_sex"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        baseLineView:horizontalPadding="10dp"
                        baseLineView:leftText="@string/person_setting_text1"
                        baseLineView:leftTextColor="@color/text_menu"
                        baseLineView:leftTextSize="16sp"
                        baseLineView:rightImageVisible="false"
                        baseLineView:rightText="女"
                        baseLineView:rightTextColor="@color/text_menu_60"
                        baseLineView:rightTextSize="16sp"/>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <com.coollang.tennis.widget.BaseLineView
                        android:id="@+id/blv_setting_height"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        baseLineView:horizontalPadding="10dp"
                        baseLineView:leftText="@string/person_setting_text2"
                        baseLineView:leftTextColor="@color/text_menu"
                        baseLineView:leftTextSize="16sp"
                        baseLineView:rightImageVisible="false"
                        baseLineView:rightText="173 cm"
                        baseLineView:rightTextColor="@color/text_menu_60"
                        baseLineView:rightTextSize="16sp"/>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <com.coollang.tennis.widget.BaseLineView
                        android:id="@+id/blv_setting_weight"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        baseLineView:horizontalPadding="10dp"
                        baseLineView:leftText="@string/person_setting_text3"
                        baseLineView:leftTextColor="@color/text_menu"
                        baseLineView:leftTextSize="16sp"
                        baseLineView:rightImageVisible="false"
                        baseLineView:rightText="70kg"
                        baseLineView:rightTextColor="@color/text_menu_60"
                        baseLineView:rightTextSize="16sp"/>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <RelativeLayout
                        android:orientation="vertical"
                        android:id="@+id/rl_bmi_setting"
                        android:layout_width="match_parent"
                        android:layout_height="45dp">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu"
                            android:id="@+id/item_person_setting_tv_content"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="@string/person_setting_text4"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="10sp"
                            android:textColor="@color/text_menu_60"
                            android:id="@+id/item_person_setting_tv_bmi_explain"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginBottom="2dp"
                            android:text="@string/person_setting_text5"
                            android:layout_alignParentBottom="true"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu_60"
                            android:id="@+id/item_person_setting_tv_data"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginRight="10dp"
                            android:text="25"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="10sp"
                            android:textColor="@color/white_menu_bg"
                            android:id="@+id/item_person_setting_tv_bmi_type"
                            android:background="@drawable/shap_person_setting_selector_bcg_round"
                            android:paddingLeft="5dp"
                            android:paddingRight="5dp"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:layout_marginBottom="2dp"
                            android:text="标准型"
                            android:layout_alignParentRight="true"
                            android:layout_alignParentBottom="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <com.coollang.tennis.widget.BaseLineView
                        android:id="@+id/blv_setting_birthday"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        baseLineView:horizontalPadding="10dp"
                        baseLineView:leftText="@string/person_setting_text6"
                        baseLineView:leftTextColor="@color/text_menu"
                        baseLineView:leftTextSize="16sp"
                        baseLineView:rightImageVisible="false"
                        baseLineView:rightText="1996-08-01"
                        baseLineView:rightTextColor="@color/text_menu_60"
                        baseLineView:rightTextSize="16sp"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/shap_setting_bcg_round"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="10dp">
                    <RelativeLayout
                        android:id="@+id/activity_personal_setting_rl_address"
                        android:layout_width="match_parent"
                        android:layout_height="45dp">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="@string/person_setting_text7"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu_60"
                            android:id="@+id/activity_personal_setting_tv_address"
                            android:background="@color/tranlete"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="45dp">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="@string/person_setting_text8"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="14sp"
                            android:textColor="@color/white_menu_bg"
                            android:id="@+id/activity_personal_setting_tv_right"
                            android:background="@drawable/shap_person_setting_selector_bcg_round"
                            android:paddingLeft="10dp"
                            android:paddingTop="3dp"
                            android:paddingRight="10dp"
                            android:paddingBottom="3dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:text="@string/activity_setting_right"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="14sp"
                            android:textColor="@color/white_menu_bg"
                            android:id="@+id/activity_personal_setting_tv_left"
                            android:background="@drawable/shap_person_setting_normal_bcg_round"
                            android:paddingLeft="10dp"
                            android:paddingTop="3dp"
                            android:paddingRight="10dp"
                            android:paddingBottom="3dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:text="@string/activity_setting_left"
                            android:layout_toLeftOf="@+id/activity_personal_setting_tv_right"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <RelativeLayout
                        android:id="@+id/activity_personal_setting_rl_ball_age"
                        android:layout_width="match_parent"
                        android:layout_height="45dp">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="@string/person_setting_text9"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu_60"
                            android:id="@+id/activity_personal_setting_tv_ball_age"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:text="@string/rollselector7"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/text_menu_wu"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"/>
                    <RelativeLayout
                        android:id="@+id/activity_personal_setting_rl_brand"
                        android:layout_width="match_parent"
                        android:layout_height="45dp">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="@string/person_setting_text10"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/text_menu_60"
                            android:id="@+id/activity_personal_setting_tv_brand"
                            android:background="@color/tranlete"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:text="@string/rollselector6"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
        </com.coollang.tennis.widget.MyScrollView>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_sex"
        android:background="#99000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true">
            <ImageView
                android:id="@+id/iv_male"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:src="@drawable/ic_personaldate_male"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/iv_female"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:src="@drawable/ic_personaldate_female"
                android:layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>
