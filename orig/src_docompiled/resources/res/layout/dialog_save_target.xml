<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/shap_dialog_bcg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="20sp"
        android:textColor="@color/black"
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:id="@+id/dialog_save_target_tv_title"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="30dp"
        android:layout_marginRight="20dp"
        android:text="@string/isSave"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/black"
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:id="@+id/dialog_save_target_tv_content"
        android:visibility="visible"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        android:text="@string/video_content"/>
    <EditText
        android:textSize="15sp"
        android:textColor="@color/black"
        android:textColorHint="#c4c4c6"
        android:layout_gravity="center_horizontal"
        android:id="@+id/dialog_save_target_et_name"
        android:background="@drawable/dialog_et_bcg"
        android:paddingLeft="3dp"
        android:paddingTop="12dp"
        android:paddingRight="3dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        android:hint="@string/input_name"
        android:singleLine="true"/>
    <View
        android:background="@color/line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="20dp"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="10dp">
        <Button
            android:textSize="16sp"
            android:textColor="@color/line"
            android:id="@+id/dialog_save_target_btn_cancel"
            android:background="@drawable/shap_dialog_btn_cancel_bcg"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="115dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:text="@string/unSave"/>
        <Button
            android:textSize="16sp"
            android:textColor="@color/text_menu_checked"
            android:id="@+id/dialog_save_target_btn_confirm"
            android:background="@drawable/shap_dialog_btn_confirm_bcg"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="115dp"
            android:layout_height="wrap_content"
            android:text="@string/save"/>
    </LinearLayout>
</LinearLayout>
