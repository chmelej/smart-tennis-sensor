<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/parent"
    android:background="#b0000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_pop"
        android:background="@drawable/updateyuanjiao"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="289dp"
        android:layout_height="340dp"
        android:layout_marginTop="60dp"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/text1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="30dp"
            android:layout_marginRight="14dp"
            android:text="@string/start_device2"/>
        <RelativeLayout
            android:id="@+id/layout1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_below="@+id/text1"
            android:layout_centerHorizontal="true">
            <ImageView
                android:id="@+id/img1"
                android:layout_width="220dp"
                android:layout_height="178dp"
                android:src="@drawable/firstlogin_pop_pic"/>
        </RelativeLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="21dp"
            android:layout_marginBottom="15dp"
            android:text="@string/start_device3"
            android:layout_alignBottom="@+id/layout1"
            android:layout_alignParentRight="true"/>
        <TextView
            android:id="@+id/gang"
            android:background="#ccc"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="21dp"
            android:layout_below="@+id/layout1"/>
        <LinearLayout
            android:id="@+id/layou2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_below="@+id/gang"
            android:layout_centerHorizontal="true">
            <TextView
                android:textColor="#7c7b80"
                android:gravity="center"
                android:id="@+id/cancel"
                android:background="@drawable/shap_firstlogin_pop"
                android:layout_width="117dp"
                android:layout_height="37dp"
                android:text="@string/start_device4"/>
            <TextView
                android:textColor="#7c7b80"
                android:gravity="center"
                android:id="@+id/content_device"
                android:background="@drawable/shap_firstlogin_pop"
                android:layout_width="117dp"
                android:layout_height="37dp"
                android:layout_marginLeft="15dp"
                android:text="@string/start_device5"
                android:layout_below="@+id/gang"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
