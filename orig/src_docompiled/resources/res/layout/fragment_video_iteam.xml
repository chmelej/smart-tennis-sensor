<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/layout_video"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/layout_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/videoplayer_ditu"
                android:layout_width="match_parent"
                android:layout_height="201dp"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"/>
            <ImageView
                android:id="@+id/videoplayer_bgpic"
                android:background="#30000000"
                android:layout_width="match_parent"
                android:layout_height="201dp"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"/>
            <ImageView
                android:id="@+id/videoplayer"
                android:layout_width="match_parent"
                android:layout_height="201dp"/>
            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/paly_video"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layout_Title"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginLeft="10dp"
            android:layout_below="@+id/layout_main">
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#999999"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/UserName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="7dp"
                android:layout_weight="1"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/looking_msg"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="9dp"
                android:src="@drawable/look_1"
                android:layout_toLeftOf="@+id/look_count"/>
            <TextView
                android:layout_gravity="center_vertical"
                android:id="@+id/look_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="16dp"
                android:layout_toLeftOf="@+id/Collection_false"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/Collection_false"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginRight="16dp"
                android:src="@drawable/selector_iscontion"
                android:layout_toLeftOf="@+id/more"
                android:layout_centerVertical="true"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/m_more"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="11dp"
                android:src="@drawable/shouye_more"
                android:layout_alignParentRight="true"/>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="11dp"
            android:layout_marginBottom="35dp"
            android:layout_alignBottom="@+id/layout_Title">
            <com.thinkcool.circletextimageview.CircleTextImageView
                android:id="@+id/User_img"
                android:layout_width="39dp"
                android:layout_height="39dp"
                app:citv_border_color="#666666"
                app:citv_border_width="0dp"/>
        </RelativeLayout>
        <RelativeLayout
            android:background="@drawable/anying"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textColor="#fff"
                android:id="@+id/titles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="11dp"
                android:layout_marginTop="10dp"
                android:text="标题内容"
                android:layout_alignParentTop="true"/>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
