<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/sport_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/navigation_relativelayout"/>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="20dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_sex_man"
            android:layout_width="match_parent"
            android:layout_height="44dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_apple_color"
                android:layout_gravity="center_vertical"
                android:id="@+id/tv_title_check_top"
                android:paddingLeft="20dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img_sex_man"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:src="@drawable/img_sex_selected"/>
        </LinearLayout>
        <View
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginLeft="20dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_sex_woman"
            android:layout_width="match_parent"
            android:layout_height="44dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_apple_color"
                android:layout_gravity="center_vertical"
                android:id="@+id/tv_title_check_bottom"
                android:paddingLeft="20dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img_sex_woman"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:src="@drawable/img_sex_selected"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
</LinearLayout>
