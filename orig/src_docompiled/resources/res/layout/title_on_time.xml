<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navigate_bg"
    android:background="@color/text_menu_checked"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="50dp">
    <TextView
        android:textSize="@dimen/titleSize"
        android:textColor="@color/white_menu_bg"
        android:id="@+id/navigateTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/activity_real"
        android:layout_centerInParent="true"/>
    <com.coollang.tennis.widget.RippleView
        android:id="@+id/leftBtn"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:rv_centered="true"
        app:rv_rippleDuration="100">
        <Button
            android:textSize="15sp"
            android:textColor="@color/white_menu_bg"
            android:id="@+id/bt_left"
            android:background="@drawable/ic_button_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerInParent="true"/>
    </com.coollang.tennis.widget.RippleView>
    <com.coollang.tennis.widget.RippleView
        android:id="@+id/rightBtn"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_toLeftOf="@+id/rightImage"
        app:rv_alpha="0"
        app:rv_zoom="true"
        app:rv_zoomScale="1.3">
        <ImageView
            android:id="@+id/img_sound_on_time"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/real_sound_tunron"/>
    </com.coollang.tennis.widget.RippleView>
    <com.coollang.tennis.widget.RippleView
        android:id="@+id/rightImage"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        app:rv_alpha="0"
        app:rv_zoom="true"
        app:rv_zoomScale="1.3">
        <ImageView
            android:id="@+id/img_connect_on_time"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/device_unconnect_anim"/>
    </com.coollang.tennis.widget.RippleView>
</RelativeLayout>
