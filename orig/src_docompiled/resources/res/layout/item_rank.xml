<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="70dp">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/item_rank_ll"
        android:layout_width="match_parent"
        android:layout_height="70dp">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/white_menu_bg"
            android:gravity="center"
            android:id="@+id/item_rank_tv_rank"
            android:background="@color/sport_text_number"
            android:layout_width="35dp"
            android:layout_height="match_parent"
            android:text="1"/>
        <com.coollang.tennis.widget.CircleImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/item_rank_civ_head"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:id="@+id/rl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_toLeftOf="@+id/item_rank_tv_times"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_menu"
                    android:id="@+id/item_rank_tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_menu_60"
                    android:id="@+id/item_rank_tv_change"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="80dp"
                    android:singleLine="true"
                    android:layout_below="@+id/item_rank_tv_name"/>
            </RelativeLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/text_menu_60"
                android:id="@+id/item_rank_tv_times"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_alignBottom="@+id/rl"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0.5dp">
        <View
            android:id="@+id/item_rank_white_line"
            android:background="@color/sport_bg"
            android:layout_width="35dp"
            android:layout_height="0.5dp"/>
        <View
            android:background="@color/line"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
