<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutIndex"
    android:background="@color/white_real_bg"
    android:fitsSystemWindows="true"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <include
        android:id="@+id/history_title"
        layout="@layout/navigation_relativelayout"/>
    <View
        android:id="@+id/view1"
        android:background="@color/white_san"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_below="@+id/history_title"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/topView"
        android:background="@drawable/history_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/view1">
        <TextView
            android:textSize="17sp"
            android:textColor="@color/white_menu_bg"
            android:gravity="center_horizontal"
            android:id="@+id/His_month"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="315dp">
            <com.coollang.tennis.widget.MyHorizentalScrollView
                android:id="@+id/horizontalScrollView1"
                android:scrollbars="none"
                android:fadingEdge="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <RelativeLayout
                    android:id="@+id/line"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.coollang.tennis.widget.MyBarView
                        android:id="@+id/mBarChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_alignParentLeft="true"
                        android:layout_alignParentTop="true"
                        app:barNum="5"
                        app:barSpace="@dimen/common_circle_width"
                        app:indicateHeight="@dimen/indicateHeight"
                        app:indicateTextSize="@dimen/indicateTextSize"/>
                </RelativeLayout>
            </com.coollang.tennis.widget.MyHorizentalScrollView>
            <ImageView
                android:id="@+id/iv_line"
                android:background="@color/changci_num"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/indicateHeight"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"/>
            <ImageView
                android:id="@+id/iv_indicator"
                android:background="@drawable/img_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/iv_line"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
    </LinearLayout>
    <android.support.v7.widget.CardView
        android:orientation="vertical"
        android:id="@+id/cardview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:layout_below="@+id/topView"
        app:cardBackgroundColor="@color/white_menu_bg"
        app:cardElevation="0.5dp">
        <GridView
            android:gravity="center"
            android:id="@+id/gridview"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="@color/tranlete"
            android:horizontalSpacing="0dp"
            android:stretchMode="columnWidth"
            android:numColumns="3"/>
    </android.support.v7.widget.CardView>
</RelativeLayout>
