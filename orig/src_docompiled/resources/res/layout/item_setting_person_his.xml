<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="44dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/img_ck_setting_history"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:src="@drawable/img_no_ck_archieve"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_apple_color"
            android:gravity="center"
            android:id="@+id/tv_year_setting_his"
            android:layout_width="92dp"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_apple_color"
            android:id="@+id/tv_desc_setting_his"
            android:paddingTop="14dp"
            android:paddingRight="8dp"
            android:paddingBottom="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="4"/>
    </LinearLayout>
    <View
        android:background="@color/text_menu_wu"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="20dp"/>
</LinearLayout>
