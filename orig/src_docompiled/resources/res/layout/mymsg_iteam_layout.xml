<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_paly"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <com.thinkcool.circletextimageview.CircleTextImageView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/User_img"
            android:layout_width="37dp"
            android:layout_height="37dp"
            android:layout_marginLeft="11dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_head_select"
            app:citv_border_color="#666666"
            app:citv_border_width="0dp"/>
        <TextView
            android:textSize="13sp"
            android:textColor="#999999"
            android:id="@+id/person_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="28dp"
            android:text="用户名"
            android:layout_toRightOf="@+id/User_img"/>
        <RelativeLayout
            android:id="@+id/layout_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_below="@+id/person_name"
            android:layout_alignLeft="@+id/person_name">
            <ImageView
                android:id="@+id/type_img"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/look_msg"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="11sp"
                android:textColor="#999999"
                android:id="@+id/type_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:text="消息类型"
                android:layout_toRightOf="@+id/type_img"/>
        </RelativeLayout>
        <TextView
            android:textSize="11sp"
            android:textColor="#999999"
            android:id="@+id/msg_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:layout_marginBottom="13dp"
            android:text="时间"
            android:layout_below="@+id/layout_type"
            android:layout_alignLeft="@+id/layout_type"/>
    </RelativeLayout>
    <RelativeLayout
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/video_img"
            android:layout_width="110dp"
            android:layout_height="73dp"
            android:layout_marginLeft="11dp"
            android:scaleType="fitXY"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/shape_duation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="52dp">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:src="@drawable/small_paly"/>
            <TextView
                android:textSize="9sp"
                android:textColor="#fff"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/Duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
