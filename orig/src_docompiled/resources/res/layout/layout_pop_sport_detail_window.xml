<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/bg_black_90"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_root"
        android:background="@drawable/updateyuanjiao"
        android:layout_width="270dp"
        android:layout_height="@dimen/sport_detail_window_height">
        <ImageView
            android:id="@+id/img_close"
            android:padding="8dp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/img_delete_fast_use"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="@dimen/sport_detail_window_title_size"
            android:textColor="@color/black"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tv_title_sport_detail_pop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text="@string/install_way"
            android:layout_centerHorizontal="true"/>
        <View
            android:background="@color/line"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_below="@+id/tv_title_sport_detail_pop"/>
        <android.support.v4.view.ViewPager
            android:id="@+id/vp_sport_detail_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/sport_detail_window_margin_top"
            android:layout_below="@+id/tv_title_sport_detail_pop"/>
        <TextView
            android:textSize="@dimen/sport_detail_window_content_size"
            android:textColor="#595757"
            android:id="@+id/tv_content_sport_detail"
            android:paddingLeft="28dp"
            android:paddingRight="28dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sport_detail_window_margin_top"
            android:layout_below="@+id/tv_title_sport_detail_pop"
            android:lineSpacingExtra="3dp"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/ll_bottom_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_alignParentBottom="true">
            <ImageView
                android:id="@+id/dot_01"
                android:background="@drawable/selector_sport_detail_circle"
                android:layout_width="6dp"
                android:layout_height="6dp"/>
            <ImageView
                android:id="@+id/dot_02"
                android:background="@drawable/selector_sport_detail_circle"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginLeft="5dp"/>
            <ImageView
                android:id="@+id/dot_03"
                android:background="@drawable/selector_sport_detail_circle"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginLeft="5dp"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
