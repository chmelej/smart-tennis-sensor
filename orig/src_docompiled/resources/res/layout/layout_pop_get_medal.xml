<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rl_medal_root"
    android:background="@drawable/bg_medal_get"
    android:layout_width="284dp"
    android:layout_height="338dp"
    android:layout_centerInParent="true">
    <ImageView
        android:id="@+id/imgv_medal_close"
        android:padding="8dp"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="12dp"
        android:src="@drawable/img_close_medal"
        android:layout_alignParentRight="true"/>
    <ImageView
        android:id="@+id/imgv_medal_type"
        android:layout_width="130dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_model_select_1"
        android:scaleType="centerCrop"
        android:layout_centerInParent="true"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/text_menu"
        android:gravity="left"
        android:id="@+id/tv_medal_desc"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="8dp"
        android:text="@string/medal_get_str_01"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
