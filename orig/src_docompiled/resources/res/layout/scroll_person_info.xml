<?xml version="1.0" encoding="utf-8"?>
<com.coollang.tennis.widget.GetMoveScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:baseLine="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/scroll_person_info"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/gradient_person_info_bg"
            android:layout_width="match_parent"
            android:layout_height="228dp">
            <FrameLayout
                android:layout_gravity="center_horizontal"
                android:id="@+id/fl_head"
                android:background="@drawable/shape_person_head_bg"
                android:layout_width="106dp"
                android:layout_height="106dp"
                android:layout_marginTop="80dp">
                <com.coollang.tennis.widget.CircleImageView
                    android:layout_gravity="center"
                    android:id="@+id/item_fragment_ranking_iv_head"
                    android:layout_width="100dp"
                    android:layout_height="100dp"/>
            </FrameLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:background="@color/sport_bg"
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_nick_name_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_nick_name"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_sex_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_setting_text1"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_city_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_city_address"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_birthday_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_setting_text6"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_sign_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_signature"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <View
                android:background="@color/sport_bg"
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_height_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_setting_text2"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_weight_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_setting_text3"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_hand_person"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/first_hand"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_ball_age"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/person_setting_text9"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginLeft="20dp"/>
            <com.coollang.tennis.widget.BaseLineView
                android:id="@+id/blv_tennis_level"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                baseLine:leftText="@string/tennis_level"
                baseLine:leftTextColor="@color/text_apple_color"
                baseLine:leftTextSize="16sp"
                baseLine:rightDrawable="@drawable/ic_person_setting_arrow"
                baseLine:rightTextColor="#787878"
                baseLine:rightTextSize="14sp"/>
            <View
                android:background="@color/text_menu_wu"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <View
                android:background="@color/sport_bg"
                android:layout_width="match_parent"
                android:layout_height="40dp"/>
        </LinearLayout>
    </LinearLayout>
</com.coollang.tennis.widget.GetMoveScrollView>
