<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/cardview"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    card_view:cardBackgroundColor="@color/white_menu_bg"
    card_view:cardElevation="0.5dp">
    <RelativeLayout
        android:id="@+id/ll_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/ll_head"
            android:layout_width="match_parent"
            android:layout_height="33dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_alignParentLeft="true"
                android:layout_centerInParent="true">
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/text_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sport_the"/>
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/text_menu"
                    android:id="@+id/barNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dp"
                    android:layout_marginRight="3dp"
                    android:text="1"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/text_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sport_bar"/>
            </LinearLayout>
            <CheckBox
                android:textSize="14sp"
                android:textColor="@color/selector_check_sport_detail"
                android:id="@+id/ck_check_detail"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:checked="true"
                android:button="@null"
                android:text="@string/sport_view"
                android:drawableRight="@drawable/selector_check_sport_arror"
                android:drawablePadding="10dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <View
            android:id="@+id/view1"
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_below="@+id/ll_head"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_item2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_below="@+id/view1">
            <LinearLayout style="@style/cardviewA">
                <TextView
                    android:text="@string/sport_now"
                    style="@style/cardviewA_text"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/sport_text_number"
                        android:id="@+id/sport_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="3dp"
                        android:text="123"/>
                    <TextView
                        android:textStyle="bold"
                        android:text="@string/sport_now_unit"
                        style="@style/cardviewA_text"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout style="@style/cardviewA">
                <TextView
                    android:text="@string/sport_fight"
                    style="@style/cardviewA_text"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/sport_text_number"
                        android:id="@+id/sport_times"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="3dp"
                        android:text="456"/>
                    <TextView
                        android:textStyle="bold"
                        android:text="@string/sport_fight_unit"
                        style="@style/cardviewA_text"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout style="@style/cardviewA">
                <TextView
                    android:text="@string/sport_colors"
                    style="@style/cardviewA_text"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/sport_text_number"
                        android:id="@+id/sport_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="3dp"
                        android:text="789"/>
                    <TextView
                        android:textStyle="bold"
                        android:text="@string/sport_colors_unit"
                        style="@style/cardviewA_text"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@+id/view2"
            android:background="@color/text_menu_wu"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_below="@+id/ll_item2"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="31dp"
            android:layout_below="@+id/view2">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/tv_sport_max_speed"
                    android:text="@string/sport_max_speed"
                    style="@style/cardviewA_text1"/>
                <TextView
                    android:textColor="@color/sport_text_number"
                    android:id="@+id/maxspeed"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="3dp"
                    android:text="256"
                    style="@style/cardviewA_text1"/>
                <TextView
                    android:textSize="12sp"
                    android:id="@+id/maxspeed_unit"
                    android:text="@string/sport_max_speed_unit"
                    style="@style/cardviewA_text1"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/data"
                    style="@style/cardviewA_text1"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</android.support.v7.widget.CardView>
