<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/item_rank_ll"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/text_menu"
            android:gravity="center"
            android:id="@+id/item_rank_tv_rank"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:text="1"/>
        <com.coollang.tennis.widget.CircleImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/item_rank_civ_head"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:id="@+id/rl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_toLeftOf="@+id/item_rank_tv_times"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_menu"
                    android:id="@+id/item_rank_tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/text_rank_color"
                    android:id="@+id/item_rank_tv_change"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dp"
                    android:singleLine="true"
                    android:drawableLeft="@drawable/place"
                    android:drawablePadding="3dp"
                    android:layout_below="@+id/item_rank_tv_name"/>
            </RelativeLayout>
            <CheckBox
                android:textSize="12sp"
                android:textColor="@color/gray_no_device"
                android:gravity="center_horizontal"
                android:id="@+id/like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:button="@null"
                android:text="88"
                android:drawableBottom="@drawable/like_selector"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/text_rank_color"
                android:id="@+id/item_rank_tv_times"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_toLeftOf="@+id/like"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </LinearLayout>
    <View
        android:background="@color/text_menu_60"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="16dp"/>
</LinearLayout>
