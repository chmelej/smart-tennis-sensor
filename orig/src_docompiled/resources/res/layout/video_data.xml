<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="#77000000"
        style="@style/videocapture_ll">
        <TextView
            android:id="@+id/tv_rate"
            android:text="@string/rate"
            style="@style/videocapture_tv1"/>
        <com.coollang.tennis.widget.CircularSeekBar
            android:id="@+id/videocapture_pb_rate"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_rate"
            android:layout_centerHorizontal="true"
            style="?android:attr/progressBarStyleHorizontal"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:id="@+id/videocapture_tv_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="0"
            android:layout_alignTop="@+id/videocapture_pb_rate"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/tv_play_speedunit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="km/h"
            android:layout_below="@+id/videocapture_tv_rate"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:background="#77000000"
        android:layout_marginTop="2px"
        style="@style/videocapture_ll">
        <TextView
            android:id="@+id/tv_strenth"
            android:text="@string/strength"
            style="@style/videocapture_tv1"/>
        <com.coollang.tennis.widget.CircularSeekBar
            android:id="@+id/videocapture_pb_strength"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_strenth"
            android:layout_centerHorizontal="true"
            style="?android:attr/progressBarStyleHorizontal"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:id="@+id/videocapture_tv_strenth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="0"
            android:layout_alignTop="@+id/videocapture_pb_strength"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="lbf"
            android:layout_below="@+id/videocapture_tv_strenth"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:background="#77000000"
        android:layout_marginTop="2px"
        style="@style/videocapture_ll">
        <TextView
            android:id="@+id/tv_angle"
            android:text="@string/angle"
            style="@style/videocapture_tv1"/>
        <com.coollang.tennis.widget.CircularSeekBar
            android:id="@+id/videocapture_pb_angle"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_angle"
            android:layout_centerHorizontal="true"
            style="?android:attr/progressBarStyleHorizontal"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/white"
            android:id="@+id/videocapture_tv_angle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="0"
            android:layout_alignTop="@+id/videocapture_pb_angle"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="deg"
            android:layout_below="@+id/videocapture_tv_angle"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
</LinearLayout>
