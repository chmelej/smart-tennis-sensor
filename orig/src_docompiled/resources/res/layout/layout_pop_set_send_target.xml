<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_black_90"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_bottom_target"
        android:background="@color/text_menu_checked"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true">
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_target_suggest"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/suggest_value"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_target_sure"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/sure_set_target"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_root_target"
        android:background="@color/white"
        android:paddingBottom="38dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/rl_bottom_target">
        <LinearLayout
            android:gravity="bottom"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="17dp">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_menu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/speed_target_title"/>
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/yellow_re_start_ble"
                android:id="@+id/tv_target_send_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="100 km/h"/>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="250dp">
            <com.coollang.tennis.widget.VerticalProgress
                android:id="@+id/vp_send_target"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_centerHorizontal="true"/>
            <ImageView
                android:id="@+id/img_container_left"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="8dp"
                android:src="@drawable/img_left_container"
                android:layout_toLeftOf="@+id/vp_send_target"
                android:layout_alignTop="@+id/vp_send_target"/>
            <ImageView
                android:id="@+id/img_container_right"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="49dp"
                android:src="@drawable/img_right_container"
                android:layout_toRightOf="@+id/vp_send_target"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:background="@drawable/shape_round_gray_bg"
                android:layout_width="90dp"
                android:layout_height="@dimen/professional_level_height"
                android:layout_marginTop="@dimen/profess_top_margin"
                android:layout_marginRight="8dp"
                android:text="@string/official_men_level"
                android:layout_toLeftOf="@+id/img_container_left"
                android:layout_alignTop="@+id/img_container_left"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:background="@drawable/shape_round_gray_bg"
                android:layout_width="90dp"
                android:layout_height="@dimen/professional_level_height"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="@dimen/profess_top_margin"
                android:text="@string/official_woman_level"
                android:layout_toRightOf="@+id/img_container_right"
                android:layout_alignTop="@+id/img_container_right"/>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
