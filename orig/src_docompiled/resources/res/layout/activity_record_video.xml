<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <SurfaceView
        android:id="@+id/activity_record_video_surfaceview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="#8f000000"
        android:layout_width="167dp"
        android:layout_height="match_parent">
        <ImageButton
            android:layout_gravity="center_horizontal"
            android:id="@+id/activity_record_video_ib_start"
            android:background="@color/tranlete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_record_video_start"/>
        <TextView
            android:textSize="17sp"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal"
            android:id="@+id/activity_record_video_tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="00:00:00"/>
    </LinearLayout>
    <ImageButton
        android:layout_gravity="right"
        android:id="@+id/activity_record_video_ib_delete"
        android:background="@color/tranlete"
        android:padding="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="10dp"
        android:src="@drawable/ic_record_video_delete"/>
</FrameLayout>
