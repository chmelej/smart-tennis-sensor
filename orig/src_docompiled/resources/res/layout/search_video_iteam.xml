<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#fff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:id="@+id/layout_paly"
        android:layout_width="match_parent"
        android:layout_height="110dp">
        <RelativeLayout
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="99dp">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/video_img"
                android:layout_width="110dp"
                android:layout_height="73dp"
                android:layout_marginLeft="11dp"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"
                android:layout_centerInParent="true"
                android:layout_centerVertical="true"/>
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/shape_duation"
                android:layout_width="wrap_content"
                android:layout_height="19dp"
                android:layout_marginLeft="15dp"
                android:layout_marginBottom="15dp"
                android:layout_alignParentBottom="true">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:src="@drawable/small_paly"/>
                <TextView
                    android:textSize="9sp"
                    android:textColor="#fff"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/Duration"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="0"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textColor="#333333"
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="17dp"
                android:layout_marginTop="30dp"
                android:text="视频标题"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/text_title"
                android:layout_alignLeft="@+id/text_title">
                <ImageView
                    android:id="@+id/look_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/look_msg"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="12sp"
                    android:id="@+id/lk_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="1204"
                    android:layout_toRightOf="@+id/look_msg"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="#ccc"
                    android:id="@+id/CreateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="11dp"
                    android:text="时间"
                    android:layout_alignParentRight="true"/>
            </RelativeLayout>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
