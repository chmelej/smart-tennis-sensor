<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="45dp">
    <TextView
        android:textSize="16sp"
        android:textColor="@color/text_menu"
        android:id="@+id/item_person_setting_tv_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="12dp"
        android:text="@string/personal_text1"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/text_menu_60"
        android:id="@+id/item_person_setting_tv_bmi_explain"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginBottom="2dp"
        android:text="@string/person_setting_text5"
        android:layout_below="@+id/item_person_setting_tv_content"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/text_menu_60"
        android:id="@+id/item_person_setting_tv_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="10dp"
        android:text="@string/perfect_male"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/white_menu_bg"
        android:id="@+id/item_person_setting_tv_bmi_type"
        android:background="@drawable/shap_person_setting_selector_bcg_round"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="2dp"
        android:text="标准型"
        android:layout_below="@+id/item_person_setting_tv_data"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
