<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/login_bg"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <include layout="@layout/navigation_relativelayout"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@color/perfect_title_bg"
            android:paddingLeft="16dp"
            android:paddingTop="8dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white_menu_bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perfect_text1"/>
        </LinearLayout>
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/img_bg"
            android:background="@drawable/ingicon_bg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="20dp">
            <com.coollang.tennis.widget.CircleImageView
                android:id="@+id/camera"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/camera"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@color/white_liu"
            android:layout_width="match_parent"
            android:layout_height="47dp"
            android:layout_marginLeft="11dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="11dp">
            <TextView
                android:textColor="@color/sport_text_number"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:text="@string/perfect_"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_menu"
                android:gravity="center_vertical"
                android:paddingLeft="3dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/perfect_name"
                android:layout_weight="1"/>
            <EditText
                android:textSize="13sp"
                android:textColorHint="@color/text_qi"
                android:id="@+id/et_name"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:hint="@string/perfect_setname"
                android:singleLine="true"
                android:layout_weight="2"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@color/white_liu"
            android:layout_width="match_parent"
            android:layout_height="47dp"
            android:layout_marginLeft="11dp"
            android:layout_marginTop="1dp"
            android:layout_marginRight="11dp">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_menu"
                android:gravity="center_vertical"
                android:paddingLeft="17dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/perfect_sex"
                android:layout_weight="1"/>
            <RadioGroup
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/rg_sex"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2">
                <RadioButton
                    android:textColor="@color/white_menu_bg"
                    android:gravity="center"
                    android:id="@+id/male"
                    android:background="@drawable/radio_bg"
                    android:layout_width="67dp"
                    android:layout_height="23dp"
                    android:checked="true"
                    android:button="@null"
                    android:text="@string/perfect_male"/>
                <RadioButton
                    android:gravity="center"
                    android:id="@+id/female"
                    android:background="@drawable/radio_bg"
                    android:layout_width="67dp"
                    android:layout_height="23dp"
                    android:layout_marginLeft="45dp"
                    android:button="@null"
                    android:text="@string/perfect_female"/>
            </RadioGroup>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/detail_person"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>
</ScrollView>
