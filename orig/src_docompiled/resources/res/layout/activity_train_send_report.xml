<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/sport_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/navigation_relativelayout"/>
    <android.support.v7.widget.CardView
        android:layout_gravity="center_horizontal"
        android:layout_width="338dp"
        android:layout_height="87dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="23dp">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_menu"
                    android:gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/train_time"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_menu"
                    android:gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/train_total_send_count"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_menu"
                    android:gravity="center"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/train_send_target_count"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">
                <LinearLayout
                    android:gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="26dp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow_re_start_ble"
                        android:id="@+id/tv_train_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/yellow_re_start_ble"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/minute"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="26dp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow_re_start_ble"
                        android:gravity="center"
                        android:id="@+id/tv_train_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/yellow_re_start_ble"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/pat"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="26dp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow_re_start_ble"
                        android:id="@+id/tv_train_finish_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="@color/yellow_re_start_ble"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/pat"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </android.support.v7.widget.CardView>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/img_top_arrow_shadoe"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_menu"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/splite_train_bar_chart"/>
        <LinearLayout
            android:background="@color/sport_bg"
            android:layout_width="match_parent"
            android:layout_height="173dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="9dp"
            android:layout_marginRight="16dp">
            <TextView
                android:textSize="10sp"
                android:textColor="@color/text_menu_80"
                android:layout_gravity="bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:text="@string/just_speed"/>
            <com.coollang.tennis.widget.TrainBarChartView
                android:id="@+id/bar_chart_view"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/text_menu_80"
                android:layout_gravity="bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:text="km/h"
                android:layout_alignParentRight="true"/>
        </LinearLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_menu"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="9dp"
            android:text="@string/ball_speed_scatter"/>
    </LinearLayout>
    <include
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="10dp"
        layout="@layout/layout_train_scatter"/>
</LinearLayout>
