<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/updateyuanjiao"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="20sp"
        android:textColor="@color/text_menu"
        android:gravity="center_horizontal"
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"/>
    <RelativeLayout
        android:id="@+id/rl_wh"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <View
            android:background="@drawable/select_rect_shap"
            android:layout_width="match_parent"
            android:layout_height="31dp"
            android:layout_centerVertical="true"/>
        <cn.jeesoft.widget.pickerview.LoopView
            android:id="@+id/picklerview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:id="@+id/tv_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="50dp"
            android:text="cm"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/rl_birthday"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <View
            android:background="@drawable/select_rect_shap"
            android:layout_width="match_parent"
            android:layout_height="31dp"
            android:layout_centerInParent="true"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp">
            <cn.jeesoft.widget.pickerview.LoopView
                android:id="@+id/pv_year"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView
                android:textSize="20sp"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:text="@string/perfect_text4_year"/>
            <cn.jeesoft.widget.pickerview.LoopView
                android:id="@+id/pv_month"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="20sp"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:text="@string/perfect_text4_month"/>
            <cn.jeesoft.widget.pickerview.LoopView
                android:id="@+id/pv_day"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="20sp"
                android:textColor="#ffffff"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:text="@string/perfect_text4_day"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button
            android:textSize="16sp"
            android:textColor="@color/line"
            android:id="@+id/btn_cancle"
            android:background="@drawable/shap_dialog_btn_cancel_bcg"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="10dp"
            android:text="@string/cancel"
            android:layout_weight="1"/>
        <Button
            android:textSize="16sp"
            android:textColor="@color/text_menu_checked"
            android:id="@+id/btn_confirm"
            android:background="@drawable/shap_dialog_btn_confirm_bcg"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="10dp"
            android:text="@string/ok"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
