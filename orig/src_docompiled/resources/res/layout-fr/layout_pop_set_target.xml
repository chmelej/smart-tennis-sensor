<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bg_black_90"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_bottom_target"
        android:background="@color/text_menu_checked"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true">
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_target_suggest"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/suggest_value"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_target_sure"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/sure_set_target"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_root_target"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="287dp"
        android:layout_above="@+id/rl_bottom_target">
        <RadioGroup
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/rg_target"
            android:layout_width="200dp"
            android:layout_height="30dp"
            android:layout_marginTop="14dp"
            android:layout_centerInParent="true">
            <RadioButton
                android:textColor="@color/selector_white_green_color"
                android:gravity="center"
                android:id="@+id/rb_fore_hand_target"
                android:background="@drawable/selector_set_target_top_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:checked="true"
                android:button="@null"
                android:text="@string/Real_new_text111"
                android:layout_weight="1"/>
            <RadioButton
                android:textColor="@color/selector_white_green_color"
                android:gravity="center"
                android:id="@+id/rb_back_hand_target"
                android:background="@drawable/selector_set_target_top_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:button="@null"
                android:text="@string/Real_new_text122"
                android:layout_weight="1"/>
        </RadioGroup>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="bottom"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:gravity="right"
                    android:orientation="horizontal"
                    android:layout_width="83dp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/text_menu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Real_type_text5"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="@color/text_rank_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/set_target_unit"/>
                </LinearLayout>
                <com.coollang.tennis.widget.IndicatorDotSeekBar
                    android:id="@+id/ids_xuan"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="bottom"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:gravity="right"
                    android:orientation="horizontal"
                    android:layout_width="83dp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/text_menu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Real_type_text6"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="@color/text_rank_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/set_target_unit"/>
                </LinearLayout>
                <com.coollang.tennis.widget.IndicatorDotSeekBar
                    android:id="@+id/ids_ping_target"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="bottom"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:gravity="right"
                    android:orientation="horizontal"
                    android:layout_width="83dp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/text_menu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Real_type_text4"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="@color/text_rank_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/set_target_unit"/>
                </LinearLayout>
                <com.coollang.tennis.widget.IndicatorDotSeekBar
                    android:id="@+id/ids_xiao_target"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"/>
            </LinearLayout>
            <RelativeLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="89dp">
                <LinearLayout
                    android:gravity="right"
                    android:orientation="vertical"
                    android:id="@+id/ll_speed_train_target"
                    android:layout_width="83dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp">
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/text_menu"
                        android:gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/train_hand_target_speed"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="@color/text_rank_color"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(km/h)"/>
                </LinearLayout>
                <com.coollang.tennis.widget.IndicatorDotSeekBar
                    android:id="@+id/ids_speed_target"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="13dp"
                    android:layout_toRightOf="@+id/ll_speed_train_target"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
