<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/white"/>
            <corners android:radius="3dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/gray_no_device"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/red_rb_Color"/>
            <corners android:radius="3dp"/>
            <stroke
                android:width="0dp"
                android:color="@color/red_rb_Color"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/sport_rb_Color"/>
            <corners android:radius="3dp"/>
            <stroke
                android:width="0dp"
                android:color="@color/sport_rb_Color"/>
        </shape>
    </item>
</selector>
