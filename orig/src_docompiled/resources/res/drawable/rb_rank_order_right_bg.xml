<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <corners
                android:topRightRadius="2dp"
                android:bottomRightRadius="2dp"/>
            <padding
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp"/>
            <solid android:color="#25c9ad"/>
            <stroke
                android:width="1dp"
                android:color="#25c9ad"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners
                android:topRightRadius="2dp"
                android:bottomRightRadius="2dp"/>
            <padding
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp"/>
            <stroke
                android:width="1dp"
                android:color="#25c9ad"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
