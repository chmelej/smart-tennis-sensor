<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:circleImage="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <RelativeLayout
            android:id="@+id/rl_second_layout_rank"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.coollang.tennis.widget.CircleImageView
                android:id="@+id/civ_second_order_head"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:layout_centerHorizontal="true"
                circleImage:borderColor="#ff8560"
                circleImage:borderSize="2dp"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_second_rank_order"
                android:background="@drawable/shape_circle_yellow_bg"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="60dp"
                android:text="2"
                android:layout_alignTop="@+id/civ_second_order_head"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:id="@+id/tv_second_rank_name"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_below="@+id/civ_second_order_head"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/gray_no_device"
                android:id="@+id/tv_place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中国"
                android:drawableLeft="@drawable/place"
                android:drawablePadding="3dp"
                android:layout_below="@+id/tv_second_rank_name"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/white"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_second_rank_count"
                android:background="@drawable/second_place_trophy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_below="@+id/tv_place"
                android:layout_centerHorizontal="true"/>
            <CheckBox
                android:textSize="12sp"
                android:textColor="@color/gray_no_device"
                android:gravity="center_horizontal"
                android:id="@+id/second_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:button="@null"
                android:text="88"
                android:drawableBottom="@drawable/like_selector"
                android:layout_below="@+id/tv_place"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_first_layout_rank"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.coollang.tennis.widget.CircleImageView
                android:id="@+id/civ_first_order_head"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="10dp"
                android:layout_centerHorizontal="true"
                circleImage:borderColor="#ff8560"
                circleImage:borderSize="2dp"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_first_rank_order"
                android:background="@drawable/shape_circle_yellow_bg"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="70dp"
                android:text="1"
                android:layout_alignTop="@+id/civ_first_order_head"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:id="@+id/tv_first_rank_name"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:singleLine="true"
                android:layout_below="@+id/tv_first_rank_order"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/gray_no_device"
                android:id="@+id/tv_first_place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中国"
                android:drawableLeft="@drawable/place"
                android:drawablePadding="3dp"
                android:layout_below="@+id/tv_first_rank_name"
                android:layout_alignLeft="@+id/tv_first_rank_name"
                android:layout_alignStart="@+id/tv_first_rank_name"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/white"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_first_rank_count"
                android:background="@drawable/champion_trophy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_below="@+id/tv_first_place"
                android:layout_centerHorizontal="true"/>
            <CheckBox
                android:textSize="12sp"
                android:textColor="@color/gray_no_device"
                android:gravity="center_horizontal"
                android:id="@+id/first_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:button="@null"
                android:text="88"
                android:drawableBottom="@drawable/like_selector"
                android:layout_below="@+id/tv_first_place"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_third_layout_rank"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.coollang.tennis.widget.CircleImageView
                android:id="@+id/civ_third_order_head"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:layout_centerHorizontal="true"
                circleImage:borderColor="#ff8560"
                circleImage:borderSize="2dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/tv_third_rank_order"
                android:background="@drawable/shape_circle_yellow_bg"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="46dp"
                android:text="3"
                android:layout_alignTop="@+id/civ_third_order_head"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/text_menu"
                android:id="@+id/tv_third_rank_name"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:singleLine="true"
                android:layout_below="@+id/tv_third_rank_order"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/gray_no_device"
                android:id="@+id/tv_third_place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中国"
                android:drawableLeft="@drawable/place"
                android:drawablePadding="3dp"
                android:layout_below="@+id/tv_third_rank_name"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/white"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_third_rank_count"
                android:background="@drawable/third_place_trophy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_below="@+id/tv_third_place"
                android:layout_centerHorizontal="true"/>
            <CheckBox
                android:textSize="12sp"
                android:textColor="@color/gray_no_device"
                android:gravity="center_horizontal"
                android:id="@+id/third_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:button="@null"
                android:text="88"
                android:drawableBottom="@drawable/like_selector"
                android:layout_below="@+id/tv_third_place"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
    </LinearLayout>
    <include layout="@layout/layout_ranking_me"/>
    <View
        android:background="@color/text_menu_60"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"/>
</LinearLayout>
