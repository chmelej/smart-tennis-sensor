<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app1="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/fragment_stroke_analysis_ll_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="210dp">
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pie_chart"
                    android:visibility="visible"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <RelativeLayout
                    android:id="@+id/rl_pie_chart_center"
                    android:layout_width="110dp"
                    android:layout_height="90dp"
                    android:layout_centerInParent="true">
                    <TextView
                        android:textSize="@dimen/sport_detail_chart_top_size"
                        android:textColor="@color/text_menu"
                        android:gravity="center_horizontal"
                        android:id="@+id/fragment_stroke_analysis_tv_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/sport_pie_chart_hit_top"
                        android:layout_centerHorizontal="true"/>
                    <TextView
                        android:textSize="@dimen/sport_detail_chart_bottom_size"
                        android:textColor="@color/text_menu_checked"
                        android:gravity="center_horizontal"
                        android:id="@+id/fragment_stroke_analysis_tv_data"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="0"
                        android:layout_below="@+id/fragment_stroke_analysis_tv_type"
                        android:layout_centerHorizontal="true"/>
                    <TextView
                        android:textSize="40sp"
                        android:textColor="@color/text_menu_checked"
                        android:gravity="center_horizontal"
                        android:id="@+id/tv_content_count_data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:layout_below="@+id/fragment_stroke_analysis_tv_type"
                        android:layout_centerHorizontal="true"/>
                </RelativeLayout>
            </RelativeLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="10dp">
                <RelativeLayout style="@style/stroke_analysis_rl">
                    <ImageView
                        android:id="@+id/iv_faqiu"
                        android:background="@drawable/shap_faqiu_circle"
                        style="@style/stroke_analysis_iv"/>
                    <TextView
                        android:text="@string/Real_type_text1"
                        android:layout_toRightOf="@+id/iv_faqiu"
                        style="@style/stroke_analysis_tv"/>
                </RelativeLayout>
                <RelativeLayout style="@style/stroke_analysis_rl">
                    <ImageView
                        android:id="@+id/iv_kousha"
                        android:background="@drawable/shap_kousha_circle"
                        style="@style/stroke_analysis_iv"/>
                    <TextView
                        android:text="@string/Real_type_text2"
                        android:layout_toRightOf="@+id/iv_kousha"
                        style="@style/stroke_analysis_tv"/>
                </RelativeLayout>
                <RelativeLayout style="@style/stroke_analysis_rl">
                    <ImageView
                        android:id="@+id/iv_jieqiu"
                        android:background="@drawable/shap_jieqiu_circle"
                        style="@style/stroke_analysis_iv"/>
                    <TextView
                        android:text="@string/Real_type_text3"
                        android:layout_toRightOf="@+id/iv_jieqiu"
                        style="@style/stroke_analysis_tv"/>
                </RelativeLayout>
                <RelativeLayout style="@style/stroke_analysis_rl">
                    <ImageView
                        android:id="@+id/iv_xiaoqiu"
                        android:background="@drawable/shap_xiaoqiu_circle"
                        style="@style/stroke_analysis_iv"/>
                    <TextView
                        android:text="@string/Real_type_text4"
                        android:layout_toRightOf="@+id/iv_xiaoqiu"
                        style="@style/stroke_analysis_tv"/>
                </RelativeLayout>
                <RelativeLayout style="@style/stroke_analysis_rl">
                    <ImageView
                        android:id="@+id/iv_xuanqiu"
                        android:background="@drawable/shap_xuanqiu_circle"
                        style="@style/stroke_analysis_iv"/>
                    <TextView
                        android:text="@string/Real_type_text5"
                        android:layout_toRightOf="@+id/iv_xuanqiu"
                        style="@style/stroke_analysis_tv"/>
                </RelativeLayout>
                <RelativeLayout style="@style/stroke_analysis_rl">
                    <ImageView
                        android:id="@+id/iv_pingji"
                        android:background="@drawable/shap_pingji_circle"
                        style="@style/stroke_analysis_iv"/>
                    <TextView
                        android:text="@string/Real_type_text6"
                        android:layout_toRightOf="@+id/iv_pingji"
                        style="@style/stroke_analysis_tv"/>
                </RelativeLayout>
            </LinearLayout>
            <View
                android:background="@color/sport_bg"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="10dp"/>
            <LinearLayout
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp">
                <RelativeLayout
                    android:id="@+id/rl_power_sport_detail"
                    style="@style/stroke_analysis_rl">
                    <TextView
                        android:gravity="center"
                        android:id="@+id/tv_title1"
                        android:text="@string/sport_resport_15"
                        style="@style/stroke_analysis_tv_2"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="#25c9ad"
                        android:gravity="center"
                        android:id="@+id/tv_level_strength_sport_detail"
                        android:background="@drawable/sport_detail_level_bg"
                        android:layout_width="46dp"
                        android:layout_height="15dp"
                        android:layout_marginTop="6dp"
                        android:layout_below="@+id/tv_title1"
                        android:layout_centerHorizontal="true"/>
                    <com.coollang.tennis.widget.SportCircleProgressView
                        android:id="@+id/circleView1"
                        android:layout_below="@+id/tv_level_strength_sport_detail"
                        app1:ringWidth="5dp"
                        app1:singleColor="@color/text_menu_checked"
                        style="@style/stroke_analysis_circle"/>
                    <LinearLayout
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/circleView1"
                        android:layout_alignBottom="@+id/circleView1"
                        android:layout_centerHorizontal="true">
                        <com.coollang.tennis.widget.CountView
                            android:textSize="20sp"
                            android:textColor="@color/text_menu"
                            android:id="@+id/countview_sport_circleView1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textSize="20sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="%"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/rl_keep_sport_detail"
                    style="@style/stroke_analysis_rl">
                    <TextView
                        android:gravity="center"
                        android:id="@+id/tv_title2"
                        android:text="@string/sport_resport_10"
                        style="@style/stroke_analysis_tv_2"/>
                    <TextView
                        android:textSize="11sp"
                        android:textColor="#ff8560"
                        android:gravity="center"
                        android:id="@+id/tv_level_keep_sport_detail"
                        android:background="@drawable/sport_detail_level_bg"
                        android:layout_width="46dp"
                        android:layout_height="15dp"
                        android:layout_marginTop="6dp"
                        android:layout_below="@+id/tv_title2"
                        android:layout_centerHorizontal="true"/>
                    <com.coollang.tennis.widget.SportCircleProgressView
                        android:id="@+id/circleView2"
                        android:layout_below="@+id/tv_level_keep_sport_detail"
                        app1:ringWidth="5dp"
                        app1:singleColor="@color/yellow_re_start_ble"
                        style="@style/stroke_analysis_circle"/>
                    <LinearLayout
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/circleView2"
                        android:layout_alignBottom="@+id/circleView2"
                        android:layout_centerHorizontal="true">
                        <com.coollang.tennis.widget.CountView
                            android:textSize="20sp"
                            android:textColor="@color/text_menu"
                            android:id="@+id/countview_sport_circleView2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textSize="20sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="%"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/rl_deep_sport_detail"
                    style="@style/stroke_analysis_rl">
                    <TextView
                        android:textSize="11sp"
                        android:textColor="#f84444"
                        android:gravity="center"
                        android:id="@+id/tv_level_deep_radio_detail"
                        android:background="@drawable/sport_detail_level_bg"
                        android:layout_width="46dp"
                        android:layout_height="15dp"
                        android:layout_marginTop="6dp"
                        android:layout_below="@+id/tv_title3"
                        android:layout_centerHorizontal="true"/>
                    <com.coollang.tennis.widget.SportCircleProgressView
                        android:id="@+id/circleView3"
                        android:layout_below="@+id/tv_level_deep_radio_detail"
                        app1:ringWidth="5dp"
                        app1:singleColor="#f84444"
                        style="@style/stroke_analysis_circle"/>
                    <LinearLayout
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/circleView3"
                        android:layout_alignBottom="@+id/circleView3"
                        android:layout_centerHorizontal="true">
                        <com.coollang.tennis.widget.CountView
                            android:textSize="20sp"
                            android:textColor="@color/text_menu"
                            android:id="@+id/countview_sport_circleView3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textSize="20sp"
                            android:textColor="@color/text_menu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="%"/>
                    </LinearLayout>
                    <TextView
                        android:gravity="center"
                        android:id="@+id/tv_title3"
                        android:text="@string/sport_resport_11"
                        android:layout_alignParentLeft="true"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        style="@style/stroke_analysis_tv_2"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
        <View
            android:background="@color/sport_bg"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"/>
        <include layout="@layout/layout_sport_detail_analysis_data"/>
        <View
            android:background="@color/sport_bg"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="24dp"/>
        <com.coollang.tennis.widget.HandView
            android:id="@+id/hand_view_sport_detail"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"/>
        <View
            android:background="@color/sport_bg"
            android:layout_width="match_parent"
            android:layout_height="6dp"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/text_menu"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/sport_resport_12"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#dd7c7b80"
            android:layout_gravity="center_horizontal"
            android:id="@+id/fragment_stroke_analysis_tv_cannot_draw_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cannot_drawLine"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#dd7c7b80"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="@string/sport_resport_13"/>
        <com.github.mikephil.charting.charts.CombinedChart
            android:id="@+id/combined_chart"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="5dp"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#dd7c7b80"
            android:layout_gravity="right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:text="@string/sport_resport_14"/>
        <View
            android:background="@color/sport_bg"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"/>
    </LinearLayout>
</ScrollView>
