<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:circleImage="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rlroot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginRight="10dp">
    <RelativeLayout
        android:id="@+id/rl_rank_no_head"
        android:background="@drawable/shape_rank_self_bg"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_marginLeft="4dp">
        <com.coollang.tennis.widget.CircleImageView
            android:id="@+id/civ_empty_head"
            android:visibility="gone"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginLeft="50dp"
            android:src="@drawable/ic_head_select"
            android:layout_centerVertical="true"
            circleImage:borderColor="#a8e9de"
            circleImage:borderSize="2dp"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/white"
            android:id="@+id/tv_no_head"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:text="@string/rank_no_head"
            android:layout_toRightOf="@+id/civ_empty_head"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/rl_rank_has_head"
        android:background="@drawable/shape_rank_self_bg"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true">
        <com.coollang.tennis.widget.CircleImageView
            android:id="@+id/civ_head_rank_self"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginLeft="50dp"
            android:layout_centerVertical="true"
            circleImage:borderColor="#a8e9de"
            circleImage:borderSize="2dp"/>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_toRightOf="@+id/civ_head_rank_self"
            android:layout_centerVertical="true">
            <TextView
                android:textSize="20sp"
                android:textColor="@color/white"
                android:id="@+id/item_rank_tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/white"
                android:id="@+id/item_rank_tv_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:singleLine="true"
                android:drawableLeft="@drawable/arrow_up"
                android:drawablePadding="3dp"
                android:layout_toRightOf="@+id/item_rank_tv_name"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/white"
                android:gravity="center_horizontal"
                android:id="@+id/me_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:button="@null"
                android:text="88"
                android:drawableBottom="@drawable/like_self"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/white"
                android:id="@+id/item_rank_tv_times"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_toLeftOf="@+id/me_like"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <TextView
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_self_order_rank"
        android:background="@drawable/lable_rank_self"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/me"
        android:layout_centerVertical="true"/>
</RelativeLayout>
